# ===================
# MCP Server Configuration
# ===================

# EverMemOS backend URL (used by MCP server to call REST API)
# Local: http://localhost:1995
# Docker / cloud: http://<your-server-ip>:1995
EVERMEMOS_BASE_URL=http://localhost:1995

# Default identity injected into every memory request
# Change to your name or a stable identifier
EVERMEMOS_USER_ID=default_user
EVERMEMOS_GROUP_ID=default_group

# MCP HTTP server port (for remote / browser plugin access)
MCP_PORT=3456
